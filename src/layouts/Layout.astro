---
import { FILMS } from "../filmdata";

const date = new Date();
const filmsNumber = FILMS.length;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Когда-куда?</title>
    <meta property="og:url" content="https://calmowl.github.io/bioaero/" />
    <meta property="og:title" content="Когда-куда?" />
    <meta property="og:image" content="/bioaero/favicon/apple-touch-icon.png" />
    <meta
      property="og:image:alt"
      content="Билет голубого цвета с изображением кадра посередине"
    />
    <meta
      property="og:description"
      content="Выбираем, где и когда молча посидим вместе пару часов"
    />
    <meta property="og:locale" content="ru" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="/bioaero/style.css" rel="stylesheet" />

    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/bioaero/favicon/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/bioaero/favicon/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/bioaero/favicon/favicon-16x16.png"
    />
    <link rel="icon" href="/bioaero/favicon/favicon.ico" />
    <link rel="manifest" href="/bioaero/favicon/site.webmanifest" />
  </head>

  <body>
    <div class="page-wrapper">
      <header>
        <a href="/bioaero" class="header_title">
          <img
            class="header-logo"
            src="/bioaero/ticket.png"
            alt="Билет голубого цвета с изображением кадра посередине"
          />
          Когда-куда?
        </a>
        <div class="header_wrapper">
          <div class="header_info">
            <p>
              Сегодня {
                date.toLocaleString("ru-RU", {
                  weekday: "short",
                  day: "numeric",
                  month: "2-digit",
                })
              },
            </p>
            <p>в афише {filmsNumber} фильмов</p>
          </div>
          <a href="/bioaero/personal-plan" class="header_favourites">
            <span class="favourites__icon"></span>
            Мои сеансы
          </a>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer>
        <a class="footer-link" href="https://t.me/ahojbiograf"
          ><span class="footer-telegram"></span>choose wisely</a
        >
        <a
          class="footer-credits"
          href="https://www.flaticon.com/free-icons/movie-tickets"
          title="movie tickets icons"
          >Movie tickets icons created by Freepik - Flaticon</a
        >
      </footer>
    </div>
  </body>
</html>

<style>
  header,
  footer {
    flex-grow: 0;
    flex-shrink: 0;
  }

  header {
    display: flex;
    align-items: center;
    justify-content: space-between;

    @media (max-width: 560px) {
      flex-direction: column;
      align-items: normal;
      margin: 0.5rem 0;
      gap: 0.7rem;
      /* display: grid;
      grid-template-columns: auto 1fr; */
    }
  }

  .header_title {
    display: flex;
    align-items: center;
    margin: 0;
  }

  .header-logo {
    width: 64px;
    height: 64px;

    @media (max-width: 560px) {
      margin-left: -10px;
    }
  }

  .header_wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    align-items: end;

    @media (max-width: 560px) {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .header_wrapper * {
    margin: 0;
  }

  .header_info {
    display: flex;
    gap: 0.3ch;

    @media (max-width: 560px) {
      display: revert;
    }
  }

  .header_info * {
    font-size: 1.3rem;
    font-weight: 500;
    text-align: end;

    @media (max-width: 560px) {
      margin: 0;
      font-size: 1rem;
      text-align: revert;
    }
  }

  .header_favourites {
    font-size: 1.5rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;

    @media (max-width: 560px) {
      font-size: 1rem;
    }
  }

  .favourites__icon {
    display: block;
    width: 26px;
    height: 26px;
    mask-repeat: no-repeat;
    mask-position: center;
    mask-size: contain;
    mask-image: url("/bioaero/svg/favourites.svg");
    background-color: var(--color-accent);
  }

  header a:hover .favourites__icon,
  header a:focus-visible .favourites__icon {
    background-color: var(--color-white);
  }

  header a:hover,
  header a:focus-visible {
    color: var(--color-white);
  }
  header a:active {
    color: var(--color-accent);
  }
</style>
