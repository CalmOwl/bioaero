---
import type { Film } from "../types";
import FilmScreening from "./FilmScreening.astro";

interface Props {
  film: Film;
}

const { film } = Astro.props;
---

<div class="film">
  {
    film.poster ? (
      <img
        class="film-poster"
        src={`/bioaero/poster/${film.poster.src}`}
        alt={`${film.poster.alt}`}
      />
    ) : (
      <img
        class="film-poster zero-poster"
        src="/bioaero/svg/clapperboard-question-mark.svg"
        alt="Знак вопроса на фоне кинохлопушки"
      />
    )
  }
  <div class="film-info">
    <h2 class="film-title">{film.title}</h2>
    <a class="film-trailer" href={film.trailerUrl}>
      {
        film.infoButtonDescription || (
          <>
            <span class="icon" />
            трейлер
          </>
        )
      }
    </a>
    {film.description && <p>{film.description}</p>}
    <ul class="film-screening">
      {
        film.screenings.map((screening, i) => (
          <FilmScreening
            screening={screening}
            filmTitle={film.title}
            screeningId={`${film.title}-${screening.date}-${screening.time}-${screening.place}`
              .toLowerCase()
              .replace(/\s+/g, "-")}
          />
        ))
      }
    </ul>
  </div>
</div>

<style>
  .film {
    display: flex;
    gap: 1.5em;
    margin: 1rem 0;
    padding: 1rem;
    background-color: var(--color-accent);
    border-radius: calc(1rem + 12px);

    @media (max-width: 560px) {
      flex-direction: column;
      margin: 0.5rem 0;
      gap: 1rem;
    }
  }

  .film-poster {
    display: block;
    flex-shrink: 0;
    width: 250px;
    height: auto;
    border-radius: 1rem;
    align-self: flex-start;

    @media (max-width: 560px) {
      max-width: 150px;
      align-self: center;
    }
  }

  .zero-poster {
    align-self: center;

    @media (max-width: 560px) {
      max-width: 150px;
    }
  }

  .film-info {
    flex-grow: 1;
  }

  .film-title {
    font-weight: 600;

    @media (max-width: 560px) {
      margin: 0 0 0.5rem 0;
      font-size: 1.3rem;
      text-align: center;
    }
  }

  .film-trailer {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    width: fit-content;
    border-radius: 1rem;
    padding: 0.5rem 1rem;
    background-color: var(--color-grey);

    @media (max-width: 560px) {
      margin: 0 auto;
    }
  }

  .film-trailer .icon {
    display: block;
    width: 32px;
    height: 32px;
    mask-repeat: no-repeat;
    mask-position: center;
    mask-size: contain;
    mask-image: url("/bioaero/svg/youtube.svg");
    background-color: var(--color-black);
  }

  .film-trailer:hover,
  .film-trailer:focus-visible {
    background-color: var(--color-white);
  }

  .film-trailer:hover .icon,
  .film-trailer:focus-visible .icon {
    background-color: var(--color-youtube);
  }

  .film-screening {
    list-style: none;
    margin: 2rem 0;
    padding: 0;
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));

    @media (max-width: 560px) {
      margin: 1rem 0;
    }
  }

  .film-screening li {
    flex-grow: 1;
  }

  .film-screening li > p {
    margin: 0;
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
    font-weight: 500;
  }
</style>
