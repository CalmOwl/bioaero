---
import { FILMS } from "../filmdata";
import FilmCard from "../components/FilmCard.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  {FILMS.map((film) => <FilmCard film={film} />)}
</Layout>

<style>
  a {
    color: var(--color-grey);
    font-size: 1.2rem;
    font-weight: 600;
  }
</style>

<script>
  import type { SavedScreening } from "../types";
  import { getSavedScreenings, toggleScreening } from "../scripts/wishlist";

  function setButtonState(btn: HTMLElement, isSaved: boolean) {
    const label = btn.querySelector(".screening-wishlist__label");
    const icon = btn.querySelector(".screening-wishlist__icon");

    if (isSaved) {
      btn.classList.add("is-saved");
      if (label) {
        label.textContent = "иду!";
        icon?.classList.add("is-active");
      }
    } else {
      btn.classList.remove("is-saved");
      if (label) {
        label.textContent = "хочу пойти";
        icon?.classList.remove("is-active");
      }
    }
  }

  function updateButtonsState() {
    const saved = getSavedScreenings();

    const buttons = document.querySelectorAll(".screening-wishlist");

    buttons.forEach((btn) => {
      if (!(btn instanceof HTMLElement)) return;

      const id = btn.dataset.id;
      if (!id) return;

      const exists = saved.some((screening) => screening.id === id);
      setButtonState(btn, exists);
    });
  }

  document.addEventListener("click", (event) => {
    if (!(event.target instanceof HTMLElement)) return;

    const btn = event.target.closest(".screening-wishlist");
    if (!(btn instanceof HTMLElement)) return;

    const id = btn.dataset.id;
    if (!id) return;

    const screening: SavedScreening = {
      id,
      film: btn.dataset.film ?? "",
      date: btn.dataset.date ?? "",
      time: btn.dataset.time ?? "",
      place: btn.dataset.place ?? "",
      ticketsUrl: btn.dataset.ticketsUrl ?? "",
    };

    const wasAdded = toggleScreening(screening);
    setButtonState(btn, wasAdded);
  });

  updateButtonsState();
</script>
